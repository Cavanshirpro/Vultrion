    );
    border: 2px solid #2d2d2d;
}

/* ============= GROUP BOX ============= */
QGroupBox {
    color: #e0e0e0;
    border: 2px solid #3a3a3a;
    border-radius: 6px;
    margin-top: 10px;
    padding-top: 10px;
    font-weight: 500;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    margin-left: 12px;
    margin-top: -8px;
    padding: 2px 6px;
    background-color: #1a1a1a;
    color: #4fc3f7;
}

QGroupBox:hover {
    border: 2px solid #4a4a4a;
}

QGroupBox:focus {
    border: 2px solid #4fc3f7;
}

/* ============= TRANSITIONS & EFFECTS ============= */
* {
    outline: none;
}