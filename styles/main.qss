/* ============= GLOBAL STYLES ============= */
QMainWindow#MainWindow {
    background-color: #1a1a1a;
}

QWidget {
    color: #e0e0e0;
    font-size: 12px;
}

/* ============= TAB WIDGET ============= */
QTabWidget::pane {
    border: 1px solid #2d2d2d;
    background: #1a1a1a;
    top: -1px;
}

QTabBar {
    background: transparent;
}

QTabBar::tab {
    background: #252525;
    color: #888888;
    padding: 8px 18px;
    margin-right: 2px;
    border: 1px solid #3a3a3a;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    font-weight: 500;
}

QTabBar::tab:hover {
    background: #2d2d2d;
    color: #ffffff;
    border: 1px solid #4fc3f7;
}

QTabBar::tab:selected {
    background: #1a1a1a;
    color: #4fc3f7;
    border: 1px solid #2d2d2d;
    border-bottom: 3px solid #4fc3f7;
    font-weight: bold;
}

QTabBar::tab:!selected {
    margin-top: 2px;
}

/* ============= LIST WIDGET ============= */
QListWidget {
    background-color: #1a1a1a;
    border: 1px solid #2d2d2d;
    border-radius: 6px;
    outline: none;
    padding: 5px;
}

QListWidget::item {
    background-color: #252525;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    margin: 2px;
    padding: 8px;
    color: #e0e0e0;
}

QListWidget::item:hover {
    background-color: #2d2d2d;
    border: 1px solid #4fc3f7;
}

QListWidget::item:selected {
    background-color: #1a1a1a;
    border: 2px solid #4fc3f7;
    color: #4fc3f7;
}

QListWidget::item:alternate {
    background-color: #202020;
}

/* ============= SCROLL BAR ============= */
QScrollBar:vertical {
    background-color: #1a1a1a;
    width: 12px;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background-color: #4a4a4a;
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #5a5a5a;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    background: none;
    border: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

/* ============= TEXT INPUT ============= */
QLineEdit {
    background-color: #252525;
    border: 2px solid #3a3a3a;
    border-radius: 5px;
    padding: 8px;
    color: #e0e0e0;
    selection-background-color: #4fc3f7;
}

QLineEdit:hover {
    border: 2px solid #4a4a4a;
}

QLineEdit:focus {
    border: 2px solid #4fc3f7;
    background-color: #1f1f1f;
}

/* ============= LABELS ============= */
QLabel {
    color: #e0e0e0;
}

/* ============= COMBO BOX ============= */
QComboBox {
    background-color: #252525;
    border: 2px solid #3a3a3a;
    border-radius: 5px;
    padding: 6px 8px;
    color: #e0e0e0;
}

QComboBox:hover {
    border: 2px solid #4a4a4a;
}

QComboBox:focus {
    border: 2px solid #4fc3f7;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #3a3a3a;
}

QComboBox::drop-down:hover {
    background-color: #4fc3f7;
}

QComboBox QAbstractItemView {
    background-color: #252525;
    color: #e0e0e0;
    selection-background-color: #4fc3f7;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
}

/* ============= BUTTONS ============= */
QPushButton {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 2px solid #3a3a3a;
    padding: 8px 16px;
    border-radius: 5px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #3a3a3a;
    border: 2px solid #4fc3f7;
}

QPushButton:pressed {
    background-color: #1f1f1f;
    border: 2px solid #4fc3f7;
}

QPushButton:disabled {
    color: #666666;
    background-color: #1f1f1f;
    border: 2px solid #2d2d2d;
}


/* ============= PROGRESS BAR ============= */
QProgressBar {
    border: 2px solid #3a3a3a;
    border-radius: 6px;
    background-color: #1f1f1f;
    height: 24px;
    text-align: center;
    color: #e0e0e0;
    font-weight: bold;
}

QProgressBar::chunk {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #00d4ff,
        stop:0.5 #4fc3f7,
        stop:1 #00d4ff
    );
    border-radius: 4px;
}

/* ============= TEXT EDIT ============= */
QTextEdit {
    background-color: #151515;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    color: #e0e0e0;
    padding: 4px;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 11px;
}

QTextEdit:focus {
    border: 1px solid #4fc3f7;
}

/* QTextEdit ScrollBar */
QTextEdit QScrollBar:vertical {
    background: #1a1a1a;
    width: 14px;
    margin: 0;
    border-radius: 7px;
}

QTextEdit QScrollBar::handle:vertical {
    background: #4a4a4a;
    border-radius: 7px;
    min-height: 20px;
}

QTextEdit QScrollBar::handle:vertical:hover {
    background: #4fc3f7;
}

QTextEdit QScrollBar::handle:vertical:pressed {
    background: #00d4ff;
}

QTextEdit QScrollBar::add-line:vertical,
QTextEdit QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

QTextEdit QScrollBar::up-arrow:vertical,
QTextEdit QScrollBar::down-arrow:vertical {
    border: none;
    background: none;
}

/* ============= SCROLLBAR ============= */
QScrollBar:vertical {
    background: #1a1a1a;
    width: 14px;
    margin: 0;
    border-radius: 7px;
}

QScrollBar::handle:vertical {
    background: #4a4a4a;
    border-radius: 7px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #4fc3f7;
}

QScrollBar::handle:vertical:pressed {
    background: #00d4ff;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

QScrollBar::up-arrow:vertical,
QScrollBar::down-arrow:vertical {
    border: none;
    background: none;
}

QScrollBar:horizontal {
    background: #1a1a1a;
    height: 14px;
    margin: 0;
    border-radius: 7px;
}

QScrollBar::handle:horizontal {
    background: #4a4a4a;
    border-radius: 7px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background: #4fc3f7;
}

/* ============= MESSAGE BOX ============= */
QMessageBox {
    background-color: #1a1a1a;
}

QMessageBox QLabel {
    color: #e0e0e0;
}

/* ============= RADIO BUTTON ============= */
QRadioButton {
    color: #e0e0e0;
    spacing: 8px;
    padding: 4px;
}

QRadioButton:hover {
    color: #4fc3f7;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border-radius: 9px;
    border: 2px solid #3a3a3a;
    background-color: #252525;
}

QRadioButton::indicator:hover {
    border: 2px solid #4fc3f7;
    background-color: #2d2d2d;
}

QRadioButton::indicator:checked {
    background: qradialgradient(
        cx:0.5, cy:0.5, radius:0.5,
        stop:0 #4fc3f7,
        stop:0.4 #00d4ff,
        stop:1 #252525
    );
    border: 2px solid #4fc3f7;
}

QRadioButton::indicator:checked:hover {
    background: qradialgradient(
        cx:0.5, cy:0.5, radius:0.5,
        stop:0 #4fc3f7,
        stop:0.4 #00d4ff,
        stop:1 #2d2d2d
    );
    border: 2px solid #00d4ff;
}

QRadioButton::indicator:disabled {
    background-color: #1f1f1f;
    border: 2px solid #2d2d2d;
}

QRadioButton::indicator:checked:disabled {
    background: qradialgradient(
        cx:0.5, cy:0.5, radius:0.5,
        stop:0 #666666,
        stop:0.4 #555555,
        stop:1 #1f1f1f
    );
    border: 2px solid #2d2d2d;
}

/* ============= CHECKBOX ============= */
QCheckBox {
    color: #e0e0e0;
    spacing: 8px;
    padding: 4px;
}

QCheckBox:hover {
    color: #4fc3f7;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3a3a3a;
    border-radius: 4px;
    background-color: #252525;
}

QCheckBox::indicator:hover {
    border: 2px solid #4fc3f7;
    background-color: #2d2d2d;
}

QCheckBox::indicator:checked {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #4fc3f7,
        stop:0.5 #00d4ff,
        stop:1 #4fc3f7
    );
    border: 2px solid #4fc3f7;
}

QCheckBox::indicator:checked:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #00d4ff,
        stop:0.5 #4fc3f7,
        stop:1 #00d4ff
    );
    border: 2px solid #00d4ff;
}

QCheckBox::indicator:disabled {
    background-color: #1f1f1f;
    border: 2px solid #2d2d2d;
}

QCheckBox::indicator:checked:disabled {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #555555,
        stop:0.5 #666666,
        stop:1 #555555
    );
    border: 2px solid #2d2d2d;
}

/* ============= LISTWIDGET & LISTVIEW CHECKBOXES ============= */
QListWidget QCheckBox {
    color: #e0e0e0;
    spacing: 8px;
    padding: 4px;
}

QListWidget QCheckBox:hover {
    color: #4fc3f7;
}

QListWidget QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3a3a3a;
    border-radius: 4px;
    background-color: #252525;
}

QListWidget QCheckBox::indicator:hover {
    border: 2px solid #4fc3f7;
    background-color: #2d2d2d;
}

QListWidget QCheckBox::indicator:checked {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #4fc3f7,
        stop:0.5 #00d4ff,
        stop:1 #4fc3f7
    );
    border: 2px solid #4fc3f7;
}

QListWidget QCheckBox::indicator:checked:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #00d4ff,
        stop:0.5 #4fc3f7,
        stop:1 #00d4ff
    );
    border: 2px solid #00d4ff;
}

QListWidget QCheckBox::indicator:disabled {
    background-color: #1f1f1f;
    border: 2px solid #2d2d2d;
}

QListWidget QCheckBox::indicator:checked:disabled {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #555555,
        stop:0.5 #666666,
        stop:1 #555555
    );
    border: 2px solid #2d2d2d;
}

/* ============= LISTVIEW CHECKBOXES ============= */
QListView {
    background-color: #1a1a1a;
    border: 1px solid #2d2d2d;
    border-radius: 6px;
    outline: none;
    padding: 5px;
}

QListView::item {
    background-color: #252525;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    margin: 2px;
    padding: 8px;
    color: #e0e0e0;
}

QListView::item:hover {
    background-color: #2d2d2d;
    border: 1px solid #4fc3f7;
}

QListView::item:selected {
    background-color: #1a1a1a;
    border: 2px solid #4fc3f7;
    color: #4fc3f7;
}

QListView::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3a3a3a;
    border-radius: 4px;
    background-color: #252525;
    margin: 2px 4px;
}

QListView::indicator:hover {
    border: 2px solid #4fc3f7;
    background-color: #2d2d2d;
}

QListView::indicator:checked {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #4fc3f7,
        stop:0.5 #00d4ff,
        stop:1 #4fc3f7
    );
    border: 2px solid #4fc3f7;
}

QListView::indicator:checked:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #00d4ff,
        stop:0.5 #4fc3f7,
        stop:1 #00d4ff
    );
    border: 2px solid #00d4ff;
}

QListView::indicator:disabled {
    background-color: #1f1f1f;
    border: 2px solid #2d2d2d;
}

QListView::indicator:checked:disabled {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #555555,
        stop:0.5 #666666,
        stop:1 #555555
    );
    border: 2px solid #2d2d2d;
}

QListView QCheckBox {
    color: #e0e0e0;
    spacing: 8px;
    padding: 4px;
}

QListView QCheckBox:hover {
    color: #4fc3f7;
}

QListView QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3a3a3a;
    border-radius: 4px;
    background-color: #252525;
}

QListView QCheckBox::indicator:hover {
    border: 2px solid #4fc3f7;
    background-color: #2d2d2d;
}

QListView QCheckBox::indicator:checked {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #4fc3f7,
        stop:0.5 #00d4ff,
        stop:1 #4fc3f7
    );
    border: 2px solid #4fc3f7;
}

QListView QCheckBox::indicator:checked:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #00d4ff,
        stop:0.5 #4fc3f7,
        stop:1 #00d4ff
    );
    border: 2px solid #00d4ff;
}

QListView QCheckBox::indicator:disabled {
    background-color: #1f1f1f;
    border: 2px solid #2d2d2d;
}

QListView QCheckBox::indicator:checked:disabled {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #555555,
        stop:0.5 #666666,
        stop:1 #555555
    );
    border: 2px solid #2d2d2d;
}

/* ============= TREEWIDGET CHECKBOXES ============= */
QTreeWidget QCheckBox {
