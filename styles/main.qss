}

/* ============= TABLEWIDGET CHECKBOXES ============= */
QTableWidget QCheckBox {
    color: #e0e0e0;
    spacing: 8px;
    padding: 4px;
}

QTableWidget QCheckBox:hover {
    color: #4fc3f7;
}

QTableWidget QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3a3a3a;
    border-radius: 4px;
    background-color: #252525;
}

QTableWidget QCheckBox::indicator:hover {
    border: 2px solid #4fc3f7;
    background-color: #2d2d2d;
}

QTableWidget QCheckBox::indicator:checked {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #4fc3f7,
        stop:0.5 #00d4ff,
        stop:1 #4fc3f7
    );
    border: 2px solid #4fc3f7;
}

QTableWidget QCheckBox::indicator:checked:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #00d4ff,
        stop:0.5 #4fc3f7,
        stop:1 #00d4ff
    );
    border: 2px solid #00d4ff;
}

QTableWidget QCheckBox::indicator:disabled {
